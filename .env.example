# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-here

# Database (SQLite — path to the .db file)
DATABASE_URL="file:./dev.db"

# Server port
PORT=3001

# ── OPTIONAL INTEGRATIONS ──────────────────────────────────────────────────────

# Stripe (stripe.com/docs/keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback

# Calendly (developer.calendly.com)
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=

# Namecheap domain registration (namecheap.com/support/api/intro)
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=

# Client URL (for CORS + OAuth redirects)
CLIENT_URL=http://localhost:5173
